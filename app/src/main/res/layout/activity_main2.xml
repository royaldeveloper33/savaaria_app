<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".MainActivity2">

    <LinearLayout
        android:layout_width="345dp"
        android:layout_height="50dp"
        android:orientation="horizontal"
        tools:layout_editor_absoluteX="33dp"
        tools:layout_editor_absoluteY="148dp">

        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="@drawable/search_full"
            android:drawableStart="@android:drawable/ic_search_category_default"

            android:gravity="center|left"

            android:hint="search anything           "
            android:paddingEnd="50dp"
            android:textColorHint="@color/black" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="74dp"
        android:layout_height="88dp"
        android:orientation="horizontal"
        tools:layout_editor_absoluteX="16dp"
        tools:layout_editor_absoluteY="25dp">

        <ImageView
            android:id="@+id/btnproflie"
            android:layout_width="40dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            app:srcCompat="@drawable/outline_account_circle_24" />

    </LinearLayout>

    <ImageView
        android:id="@+id/imageView8"
        android:layout_width="275dp"
        android:layout_height="131dp"
        app:srcCompat="@drawable/image2"
        tools:layout_editor_absoluteX="83dp"
        tools:layout_editor_absoluteY="17dp" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:layout_width="402dp"
        android:layout_height="87dp"
        tools:layout_editor_absoluteX="4dp"
        tools:layout_editor_absoluteY="643dp">

        <LinearLayout
            android:layout_width="412dp"
            android:layout_height="74dp"
            android:orientation="horizontal"


            >

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.2"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imageView"
                    android:layout_width="60dp"
                    android:layout_height="42dp"
                    android:layout_gravity="center"
                    android:tint="@color/black"
                    app:srcCompat="@drawable/outline_attribution_24"

                <TextView
                    android:id="@+id/textView8"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center"
                    android:text="Join"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.2"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imageView"
                    android:layout_width="72dp"
                    android:layout_height="42dp"
                    android:layout_gravity="center"
                    android:tint="@color/black"
                    app:srcCompat="@drawable/outline_add_24"

                <TextView
                    android:id="@+id/textView8"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center"
                    android:text="Explore"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.2"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imageView"
                    android:layout_width="72dp"
                    android:layout_height="42dp"
                    android:layout_gravity="center"
                    android:tint="@color/black"
                    app:srcCompat="@drawable/outline_browse_gallery_24" />

                <TextView
                    android:id="@+id/textView8"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center"
                    android:text="History"
                    android:textColor="@color/black"
                    android:textStyle="bold"/>

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.bottomnavigation.BottomNavigationView>


</androidx.constraintlayout.widget.ConstraintLayout>